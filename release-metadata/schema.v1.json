{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/llaurila/veeling/release-metadata/schema.v1.json",
  "title": "Veeling release metadata feed",
  "description": "Contract for CLI update-check metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "source",
    "channels"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "releases_url"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "format": "uri"
        },
        "releases_url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "channels": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable",
        "prerelease"
      ],
      "properties": {
        "stable": {
          "$ref": "#/$defs/releaseChannel"
        },
        "prerelease": {
          "oneOf": [
            {
              "$ref": "#/$defs/releaseChannel"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  },
  "$defs": {
    "releaseChannel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "tag",
        "published_at",
        "release_url",
        "notes_url",
        "changelog_url",
        "compatibility"
      ],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
        },
        "tag": {
          "type": "string",
          "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
        },
        "published_at": {
          "type": "string",
          "format": "date-time"
        },
        "release_url": {
          "type": "string",
          "format": "uri"
        },
        "notes_url": {
          "type": "string",
          "format": "uri"
        },
        "changelog_url": {
          "type": "string",
          "format": "uri"
        },
        "compatibility": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "minimum_cli_version",
            "notes"
          ],
          "properties": {
            "minimum_cli_version": {
              "oneOf": [
                {
                  "type": "string",
                  "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
                },
                {
                  "type": "null"
                }
              ]
            },
            "notes": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
